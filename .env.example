# ============================================================================
# ProjectPulse — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# All VITE_* variables are embedded in the frontend build. They are NOT secret
# but are needed so the app knows which Firebase project to connect to.
# ============================================================================

# ── Firebase Configuration ──────────────────────────────────────────────────
# Find these values in the Firebase Console:
#   Project Settings → General → Your apps → Web app → SDK setup and config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firestore database ID (leave as "(default)" unless you created a named database)
VITE_FIREBASE_DATABASE_ID=(default)

# ── Access Control ──────────────────────────────────────────────────────────
# Optional: Restrict team login to a specific email domain.
# Only Google accounts ending in @<this domain> will be allowed to sign in.
# Leave blank or remove to allow any Google account.
# Example: yourcompany.com
VITE_ALLOWED_DOMAIN=
